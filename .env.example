# Database Configuration
DATABASE_URL=postgresql+asyncpg://sales_user_agent:sales_password@localhost:5432/sales_intelligence_agent

# Milvus Configuration
MILVUS_HOST=localhost
MILVUS_PORT=19530

# JWT & Authentication Configuration
JWT_SECRET=token
ACCESS_TOKEN_EXPIRE_MINUTES=60

# LLM & Agent Configurations
# Choose: gemini, openai, or agentrouter
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
AGENT_ROUTER_API_KEY=
AGENT_ROUTER_BASE_URL=https://agentrouter.org/v1
AGENT_ROUTER_MODEL=deepseek-r1-0528

# Vector Database Embeddings
# Defaults to local "all-MiniLM-L6-v2" if empty
EMBEDDING_MODEL_NAME=

# LangSmith Tracing Configuration
LANGCHAIN_TRACING_V2=
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=sales-intelligenc

